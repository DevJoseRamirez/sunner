{%- liquid
  assign first_block = section.blocks | first
  if first_block != blank
    assign first_block_image = first_block.settings.image
    if first_block.type == 'video'
      assign first_block_image = first_block.settings.video.preview_image | default: first_block.settings.cover_image
    endif

    assign first_block_image_mobile = first_block.settings.image_mobile | default: first_block_image
    if first_block.type == 'video'
      assign first_block_image_mobile = first_block.settings.video_mobile.preview_image | default: first_block.settings.cover_image_mobile
    endif
  endif
-%}
<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- render 'section-variables', section: section -%}
    {%- if first_block_image != blank and section.settings.image_height == 'adapt' %}
      --ratio-percent: {{ 1 | divided_by: first_block_image.aspect_ratio | times: 100 }}%;
    {% endif -%}
  }

  {%- if first_block_image_mobile != blank and section.settings.image_height_mobile == 'adapt' %}
    @media screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        --ratio-percent: {{ 1 | divided_by: first_block_image_mobile.aspect_ratio | times: 100 }}%;
      }
    }
  {% endif -%}
</style>

{%- if section.blocks.size > 0 -%}
<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="{% unless section.settings.full_width %}page-width {% endunless %}relative">
    {%- if section.blocks.size > 1 and section.settings.autoplay -%}
      <button
        type="button"
        class="slideshow-control flex items-center justify-center rounded-full sr-only"
        is="control-button"
        aria-controls="Slider-{{ section.id }}"
        aria-live="polite"
      >
        <span class="slideshow-control__pause">
          {%- render 'icon', icon: 'pause' -%}
          <span class="sr-only">{{ 'sections.slideshow.pause_slideshow' | t }}</span>
        </span>
        <span class="slideshow-control__play">
          {%- render 'icon', icon: 'play' -%}
          <span class="sr-only">{{ 'sections.slideshow.play_slideshow' | t }}</span>
        </span>
      </button>
    {%- endif -%}
    <slideshow-element
      id="Slider-{{ section.id }}" class="slideshow block"{% if section.settings.autoplay %} autoplay autoplay-speed="{{ section.settings.autoplay_speed }}"{% endif %}
      role="region"
      aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
      aria-label="{{ section.settings.accessibility_info | escape }}"
    >
      {%- capture sizes -%}{% if section.settings.full_width %}100vw{% else %}min({{ settings.page_width }}px, 100vw){% endif %}{%- endcapture -%}
      {%- for block in section.blocks -%}
        {%- liquid
          if section.index == 1 and forloop.first
            assign loading = 'eager'
            assign fetchpriority = 'high'
            assign lazyimage = null
          else
            assign loading = 'lazy'
            assign fetchpriority = 'low'
            assign lazyimage = 'lazy-image'
          endif
        -%}
        {%- case block.type -%}
          {%- when 'image' -%}
            <div class="banner media--{{ section.settings.image_height }} mobile:media--{{ section.settings.image_height_mobile }} w-full overflow-hidden" data-type="image" {{ block.shopify_attributes }}>
              <media-element class="banner__media block w-full h-full overflow-hidden"{% if section.settings.enable_parallax %} data-parallax="0.3" data-parallax-dir="{{ section.settings.parallax_direction }}"{% endif %}>
                <animate-element data-animate="zoom-out" class="media media--height block w-full h-full relative overflow-hidden" paused>
                  <picture class="media media--height block w-full h-full relative overflow-hidden">
                    {%- if block.settings.image != blank -%}
                      {%- if block.settings.image_mobile -%}
                        <source
                          media="(max-width: 767px)"
                          srcset="{{ block.settings.image_mobile | image_url: width: '400x' }} 400w, {{ block.settings.image_mobile | image_url: width: '600x' }} 600w, {{ block.settings.image_mobile | image_url: width: '800x' }} 800w, {{ block.settings.image_mobile | image_url: width: '1000x' }} 1000w"
                          width="{{ block.settings.image_mobile.width }}"
                          height="{{ block.settings.image_mobile.height }}"
                        >
                      {%- endif -%}
    
                      {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: loading: loading, fetchpriority: fetchpriority, sizes: sizes, widths: '300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200', is: lazyimage, class: 'banner__image' -}}
                    {%- else -%}
                      {%- capture placeholder -%}{% cycle 'lifestyle-1', 'lifestyle-2' %}{%- endcapture -%}
                      {{- placeholder | placeholder_svg_tag: 'banner__image banner__overlay placeholder' -}}
                    {%- endif -%}
                  </picture>
                </animate-element>
              </media-element>
              <span class="banner__overlay absolute top-0 left-0 w-full h-full pointer-events-none"></span>
              {%- if block.settings.button_label == blank and block.settings.button_link != blank -%}
                <a href="{{ block.settings.button_link }}"{% if block.settings.button_external %} target="_blank" rel="noopener"{% endif %} class="block absolute top-0 left-0 w-full h-full" aria-hidden="true">&nbsp;</a>
              {%- endif -%}
            </div>

          {%- when 'video' -%}
            <div class="banner media--{{ section.settings.image_height }} mobile:media--{{ section.settings.image_height_mobile }} w-full overflow-hidden" data-type="video" {{ block.shopify_attributes }}>
              <media-element class="banner__media block w-full h-full overflow-hidden"{% if section.settings.enable_parallax %} data-parallax="0.3" data-parallax-dir="{{ section.settings.parallax_direction }}"{% endif %}>
                <animate-element data-animate="zoom-out" class="media media--height block w-full h-full relative overflow-hidden" paused>
                  {%- if block.settings.video_mobile or block.settings.video_url_mobile -%}
                    {%- render 'video',
                      sizes: sizes,
                      loading: loading,
                      fetchpriority: fetchpriority,
                      lazyimage: lazyimage,
                      video: block.settings.video_mobile,
                      video_url: block.settings.video_url_mobile,
                      muted: true,
                      autoplay: false,
                      loop: true,
                      description: block.settings.description,
                      cover_image: block.settings.cover_image_mobile,
                      show_play_button: false,
                      is_mobile: true,
                      class: 'banner__image'
                    -%}
                  {%- endif -%}
            
                  {%- render 'video',
                    sizes: sizes,
                    loading: loading,
                    fetchpriority: fetchpriority,
                    lazyimage: lazyimage,
                    video: block.settings.video,
                    video_url: block.settings.video_url,
                    muted: true,
                    autoplay: false,
                    loop: true,
                    description: block.settings.description,
                    cover_image: block.settings.cover_image,
                    show_play_button: false,
                    class: 'banner__image'
                  -%}
                </animate-element>
              </media-element>
              <span class="banner__overlay absolute top-0 left-0 w-full h-full pointer-events-none"></span>
              {%- if block.settings.button_label == blank and block.settings.button_link != blank -%}
                <a href="{{ block.settings.button_link }}"{% if block.settings.button_external %} target="_blank" rel="noopener"{% endif %} class="block absolute top-0 left-0 w-full h-full" aria-hidden="true">&nbsp;</a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </slideshow-element>
    <div class="page-width absolute bottom-0 left-0 w-full pointer-events-none">
      <div class="slideshow-content">
        <nav is="slideshow-words" class="slideshow-words grid items-center" aria-controls="Slider-{{ section.id }}" aria-labelledby="Slider-{{ section.id }}">
          {%- for block in section.blocks -%}
            <div class="slideshow-word flex flex-col md:flex-row md:items-end justify-between gap-6" data-index="{{ forloop.index0 }}" aria-current="{% if forloop.first %}true{% else %}false{% endif %}">
              {%- if block.settings.heading != blank -%}
                <div class="banner__box banner__box--{{ section.settings.content_width }}">
                  <{{ block.settings.heading_tag }} class="heading leading-none {{ block.settings.heading_size }}">
                    <split-words class="split-words js-invisible block"  data-animate-delay="250">{{ block.settings.heading }}</split-words>
                  </{{ block.settings.heading_tag }}>
                </div>
              {%- endif -%}

              {%- if block.settings.button_label != blank -%}
                {%- render 'button',
                  label: block.settings.button_label,
                  link: block.settings.button_link,
                  style: block.settings.button_style,
                  external: block.settings.button_external,
                  show_icon: block.settings.button_icon,
                  classes: 'button--blur button--fixed pointer-events-auto',
                  shopify_attributes: block.shopify_attributes
                -%}
              {%- endif -%}
            </div>
          {%- endfor -%}
        </nav>
        {%- if section.blocks.size > 1 and section.settings.show_navigation -%}
          <div class="slideshow-dots flex items-end justify-between">
            <button type="button" is="previous-button" class="hidden md:block pointer-events-auto" aria-controls="Slider-{{ section.id }}" aria-label="{{ 'general.pagination.previous' | t | escape }}">
              {%- render 'icon', icon: 'arrow-left-long', class: 'transform' -%}
            </button>
            <slider-dots class="flickity-page-dots w-auto pointer-events-auto" aria-controls="Slider-{{ section.id }}">
              {%- for block in section.blocks -%}
                <button type="button" class="flickity-page-dot" data-index="{{ forloop.index0 }}" aria-current="{% if forloop.first %}true{% else %}false{% endif %}">
                  <span class="sr-only">{{ 'general.pagination.page' | t: number: forloop.index }}</span>
                </button>
              {%- endfor -%}
            </slider-dots>
            <button type="button" is="next-button" class="hidden md:block pointer-events-auto" aria-controls="Slider-{{ section.id }}" aria-label="{{ 'general.pagination.next' | t | escape }}">
              {%- render 'icon', icon: 'arrow-right-long', class: 'transform' -%}
            </button>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>
