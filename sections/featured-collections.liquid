<style>
    #shopify-section-{{ section.id }} {
      --section-padding-top: {{ section.settings.padding_top }}px;
      --section-padding-bottom: {{ section.settings.padding_bottom }}px;
      {%- render 'section-variables', section: section -%}
    }

    #shopify-section-{{ section.id }} .tab-list {
      gap: 0 !important;
    }

    #shopify-section-{{ section.id }} .tab-list [role="tablist"] {
      gap: 0 !important;
    }

    #shopify-section-{{ section.id }} .tab__item.button {
      background: transparent !important;
    }

    #shopify-section-{{ section.id }} .tab__item.button .btn-text {
      position: relative;
      z-index: 2;
      line-height: 1.25;
    }

    #shopify-section-{{ section.id }} .tab__item.button .btn-fill {
      z-index: 1;
    }

    #shopify-section-{{ section.id }} .tab__item.button.button--primary,
    #shopify-section-{{ section.id }} .tab__item.button[aria-selected="true"] {
      background: #E5E5E5 !important;
    }

    #shopify-section-template--19782234931396__featured_collections_d8KewC .tab-list [role="tablist"] {
      gap: 0 !important;
  }
</style>

{%- liquid
  assign section_rendering_api = false
  if section.index == null
    assign section_rendering_api = true
  endif
-%}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} relative">
    {%- render 'section-heading', section: section -%}

    {%- if section.blocks.size > 0 -%}
      <tabs-element class="tab-list flex gap-6 justify-between">
        <scroll-shadow class="scroll-shadow grid overflow-hidden">
          <div class="scroll-area grid">
            <div class="flex gap-4" role="tablist">
              {%- for block in section.blocks -%}
                {%- assign collection = block.settings.collection -%}
                <button
                  class="tab__item button{% if forloop.first %} button--primary{% else %} button--secondary{% endif %} whitespace-nowrap"
                  type="button"
                  is="hover-button"
                  role="tab"
                  aria-controls="TabPanel-{{ block.id }}"
                  aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                  data-index="{{ forloop.index0 }}"
                  {{ block.shopify_attributes }}
                >
                  {%- unless forloop.first -%}
                    {%- unless section_rendering_api -%}
                      <api-button
                        class="api-only"
                        data-id="TabPanelContent-{{ block.id }}"
                        data-section-id="{{ section.id }}"
                      ></api-button>
                    {%- endunless -%}
                  {%- endunless -%}
                  <span class="btn-fill" data-fill></span>
                  <span class="btn-text">
                    {%- liquid
                      if block.settings.title != blank or collection != blank
                        echo block.settings.title | default: collection.title | escape
                      else
                        echo 'onboarding.collection_title' | t | escape
                      endif
                    -%}
                    {% comment %} testing {% endcomment %}
                    {%- if collection.all_products_count > 0 -%}
                      <small class="count font-medium absolute text-xs tracking-none whitespace-nowrap">
                        {{- collection.all_products_count -}}
                      </small>
                    {%- endif -%}
                    {% comment %} testing {% endcomment %}
                  </span>
                </button>
              {%- endfor -%}
            </div>
          </div>
          <template>
            <slot></slot>
            <s dir="{% render 'direction' %}" style="--t: 0;--b: 0;--l: 0;--r: 0;">
              <span class="l"></span>
              <span class="r"></span>
            </s>
            <style>
              :host{display:inline-block;position:relative}:host([hidden]){display:none}
              s{position:absolute;inset:0;pointer-events:none;{% if settings.card_style == 'card' %}--color-background:var(--color-placeholder){% endif %}}
              s span{position:absolute;inset-block:0;width:var(--sp-12);opacity:0;transition:opacity var(--animation-short);}
              s .l{inset-inline-start:0;opacity:var(--l);background:linear-gradient(90deg,rgb(var(--color-background)) 0%,transparent 100%);}
              s .r{inset-inline-end:0;opacity:var(--r);background:linear-gradient(270deg,rgb(var(--color-background)) 0%,transparent 100%);}
              s[dir=rtl] :is(.icon-chevron-left,.icon-chevron-right){transform:scaleX(-1);}
            </style>
          </template>
        </scroll-shadow>

        {%- if section.settings.carousel_on_desktop -%}
          {%- for block in section.blocks -%}
            <div
              class="indicators hidden lg:flex gap-2d5"
              {% unless forloop.first %}
                hidden
              {% endunless %}
              data-index="{{ forloop.index0 }}"
            >
              <button
                class="button button--secondary"
                type="button"
                is="previous-button"
                aria-controls="Slider-{{ block.id }}"
                aria-label="{{ 'general.pagination.previous' | t | escape }}"
                disabled
              >
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- render 'icon', icon: 'chevron-left', class: 'transform' -%}
                </span>
              </button>
              <button
                class="button button--secondary"
                type="button"
                is="next-button"
                aria-controls="Slider-{{ block.id }}"
                aria-label="{{ 'general.pagination.next' | t | escape }}"
              >
                <span class="btn-fill" data-fill></span>
                <span class="btn-text">
                  {%- render 'icon', icon: 'chevron-right', class: 'transform' -%}
                </span>
              </button>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </tabs-element>

      {%- for block in section.blocks -%}
        {%- liquid
          assign collection = block.settings.collection
          assign products = block.settings.products | default: collection.products
        -%}
        <div
          id="TabPanel-{{ block.id }}"
          role="tabpanel"
          {% unless forloop.first %}
            hidden
          {% endunless %}
        >
          <div id="TabPanelContent-{{ block.id }}">
            {%- if section_rendering_api or forloop.first -%}
              <slider-element
                id="Slider-{{ block.id }}"
                class="grid slider{% if section.settings.carousel_on_desktop %} slider--desktop{% endif %}{% if section.settings.swipe_on_mobile %} slider--tablet{% endif %}"
                selector=".card-grid>.card"
                {% if section.settings.carousel_on_desktop or section.settings.swipe_on_mobile %}
                  tabindex="0"
                {% endif %}
              >
                <div class="product-grid card-grid card-grid--{{ section.settings.columns }} mobile:card-grid--{{ section.settings.columns_mobile }} grid">
                  {%- for product in products limit: section.settings.product_limit -%}
                    {%- render 'product-card',
                      product: product,
                      product_id: product.id,
                      section_id: section.id,
                      block_id: block.id,
                      lazy_load: false,
                      image_ratio: settings.product_image_ratio,
                      image_fill: settings.product_image_fill,
                      show_secondary_image: settings.product_secondary_image,
                      show_vendor: settings.product_vendor,
                      show_rating: settings.product_rating,
                      show_color_swatches: settings.product_color_swatches,
                      show_countdown: settings.product_countdown,
                      show_quick_add: settings.product_quick_add,
                      show_quick_view: settings.product_quick_view,
                      vertical_badges: settings.product_vertical_badges,
                      show_sold_out: settings.product_sold_out,
                      show_save_amount: settings.product_save_amount,
                      save_type: settings.product_save_type,
                      show_icon_list: settings.product_icon_list
                    -%}
                  {%- else -%}
                    {%- for i in (1..section.settings.product_limit) -%}
                      {%- capture placeholder -%}product-{% cycle '1', '2', '3', '4', '5', '6' %}{%- endcapture -%}
                      {%- render 'product-card-placeholder',
                        placeholder: placeholder,
                        image_ratio: settings.product_image_ratio,
                        show_vendor: settings.product_vendor
                      -%}
                    {%- endfor -%}
                  {%- endfor -%}
                </div>
              </slider-element>

              {%- if section.settings.show_view_all
                and collection != blank
                and section.settings.product_limit < collection.all_products_count
              -%}
                <p class="text-center">
                  <a
                    class="button button--secondary icon-with-text"
                    href="{{ collection.url }}"
                    is="hover-link"
                    aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: collection.title }}"
                  >
                    <span class="btn-fill" data-fill></span>
                    <span class="btn-text">
                      {%- liquid
                        render 'icon', icon: 'newspaper'
                        echo 'sections.featured_collection.view_all' | t
                      -%}
                    </span>
                  </a>
                </p>
              {%- endif -%}
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    'use strict';

    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;

    var tabsEl = root.querySelector('tabs-element');
    if (!tabsEl) return;

    function toArr(nl) {
      return Array.prototype.slice.call(nl);
    }

    function activate(index) {
      var tabs = toArr(tabsEl.querySelectorAll('button[role="tab"][aria-controls][data-index]'));
      var panels = toArr(root.querySelectorAll('[role="tabpanel"][id^="TabPanel-"]'));
      var indicators = toArr(tabsEl.querySelectorAll('.indicators[data-index]'));

      for (var i = 0; i < tabs.length; i++) {
        var isActive = String(i) === String(index);
        tabs[i].classList.toggle('button--primary', isActive);
        tabs[i].classList.toggle('button--secondary', !isActive);
        tabs[i].setAttribute('aria-selected', isActive ? 'true' : 'false');
      }

      for (var p = 0; p < panels.length; p++) {
        panels[p].hidden = String(p) !== String(index);
      }

      for (var k = 0; k < indicators.length; k++) {
        indicators[k].hidden = String(indicators[k].getAttribute('data-index')) !== String(index);
      }

      var btn = tabsEl.querySelector('button[role="tab"][data-index="' + index + '"]');
      if (btn) {
        var apiBtn = btn.querySelector('api-button');
        if (apiBtn && typeof apiBtn.click === 'function') apiBtn.click();
      }
    }

    tabsEl.addEventListener('click', function (e) {
      var btn = e.target && e.target.closest ? e.target.closest('button[role="tab"][data-index]') : null;
      if (!btn || !tabsEl.contains(btn)) return;

      e.preventDefault();

      var idx = btn.getAttribute('data-index');
      if (idx == null) return;

      activate(idx);
    });

    activate(0);
  })();
</script>

{%- if section.settings.swatches_use_images -%}
  <script>
    (function () {
      'use strict';

      var sectionId = 'shopify-section-{{ section.id }}';
      var root = document.getElementById(sectionId) || document;
      if (!root) return;

      var style = document.createElement('style');
      style.innerHTML = `
    #${sectionId} .swatches .color-swatch {
      width: 8px !important;
      height: 8px !important;
      border-radius: 999px !important;
      padding: 0 !important;
      overflow: hidden !important;
      display: inline-block !important;
      background-image: none !important;
      box-shadow: none !important;
      border: 1px solid rgb(0, 0, 0) !important;
    }

    #${sectionId} .swatches .color-swatch.with-image {
      --swatch-background-image: none !important;
    }

    #${sectionId} .swatches .color-swatch::before,
    #${sectionId} .swatches .color-swatch::after {
      content: none !important;
      background: none !important;
      box-shadow: none !important;
    }
  `;
      document.head.appendChild(style);

      var MAP = {
        jet: '#0b0b0b',
        black: '#0b0b0b',

        tea: '#f2f0ea',
        cream: '#f4efe4',
        white: '#ffffff',

        soil: '#6a4a33',
        brown: '#6a4a33',

        'sun blu': '#9fb8c8',
        'sand wash': '#b8c8c9',

        'tea/pink': '#e8c8c6',
      };

      function norm(v) {
        return (v || '')
          .trim()
          .toLowerCase()
          .replace(/^['"]|['"]$/g, '');
      }

      function pickToken(el) {
        var cs = getComputedStyle(el);
        var token = norm(cs.getPropertyValue('--swatch-background'));
        if (token) return token;

        var label = el.getAttribute('aria-label') || el.getAttribute('title') || '';
        label = norm(label);
        var dash = label.lastIndexOf('-');
        if (dash !== -1) return norm(label.slice(dash + 1));

        return '';
      }

      function apply(el) {
        var token = pickToken(el);
        var color = MAP[token];
        if (!color) return;

        el.style.backgroundImage = 'none';
        el.style.setProperty('--swatch-background-image', 'none');
        el.style.backgroundColor = color;
      }

      function run() {
        var nodes = root.querySelectorAll('.swatches .color-swatch');
        for (var i = 0; i < nodes.length; i++) apply(nodes[i]);
      }

      run();

      var mo = new MutationObserver(run);
      mo.observe(root, { childList: true, subtree: true });
    })();
  </script>
{%- endif -%}

