<style>
  #shopify-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

{{ 'blog.css' | asset_url | stylesheet_tag }}
{{ 'collection.css' | asset_url | stylesheet_tag }}
{{ 'search.css' | asset_url | stylesheet_tag }}
<script src="{{ 'collection.js' | asset_url }}" defer></script>
<script src="{{ 'search.js' | asset_url }}" defer></script>

{%- liquid
  assign filter_count = 0
  for filter in search.filters
    if filter.type == 'price_range'
      if filter.max_value.value != blank or filter.min_value.value != blank
        assign filter_count = filter_count | plus: 1
      endif
    else
      assign filter_count = filter_count | plus: filter.active_values.size
    endif
  endfor

  assign enable_sorting = section.settings.enable_sorting
  assign enable_filtering = section.settings.enable_filtering
  assign show_on_model = section.settings.show_on_model
  assign filter_type = section.settings.filter_type
  assign buttons_style = section.settings.buttons_style
-%}

<div class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
  <div class="collection page-width{% if section.settings.full_width %} page-width--full{% endif %} relative{% if enable_filtering %} with-{{ filter_type }}{% endif %}">
    <div class="title-wrapper{% if section.settings.heading_size == 'title-xl' %} title-wrapper-lg{% endif %} text-center leading-none grid gap-8">
      <{{ section.settings.heading_tag }} class="heading {{ section.settings.heading_size }}" tabindex="-1">
        <split-words class="split-words js-invisible block" >
          {%- liquid
            if search.performed
              echo 'general.search.title_results' | t
            else
              echo 'general.search.title' | t
            endif
          -%}
        </split-words>
      </{{ section.settings.heading_tag }}>

      {%- render 'predictive-search', section_id: section.id, context: 'page' -%}
    </div>

    {%- paginate search.results by section.settings.products_per_page -%}
      {%- if search.results_count > 0 -%}
        {%- render 'facets-sticky',
          results: search,
          collapsed: section.settings.filter_collapsed,
          enable_color_swatches: section.settings.filter_color_swatches,
          enable_filtering: enable_filtering,
          enable_sorting: enable_sorting,
          filter_count: filter_count,
          section_id: section.id
        -%}
      {%- endif -%}

      {%- unless enable_filtering or enable_sorting -%}
        {%- if search.results_count > 0 -%}
          <div class="facet-topbar">
            <p class="text-base lg:text-lg" role="status">{{ 'general.search.results_with_count_and_term' | t: terms: search.terms, count: search.results_count }}</p>
          </div>
        {%- endif -%}
      {%- endunless -%}

      {%- if search.results_count > 0 -%}
        {%- if enable_filtering or enable_sorting -%}
          <facets-topbar id="FacetsTopbar-{{ section.id }}" class="collection__topbar hidden xl:block xl:sticky z-10" data-gap="0">
            <div class="page-width{% if section.settings.full_width %} page-width--full{% endif %} facet-topbar flex items-center gap-4">
              {%- if enable_filtering -%}
                {%- if filter_type == 'drawer' -%}
                  {%- render 'facets-drawer',
                    results: search,
                    collapsed: section.settings.filter_collapsed,
                    enable_filtering: enable_filtering,
                    enable_sorting: enable_sorting,
                    enable_color_swatches: section.settings.filter_color_swatches,
                    filter_count: filter_count,
                    buttons_style: buttons_style,
                    section_id: section.id
                  -%}
                {%- elsif filter_type == 'sidebar' -%}
                  <div class="facet-wrapper">
                    <button class="button button--{{ buttons_style }} icon-with-text" type="button" is="filters-toggle" aria-controls="FacetFiltersContainer" aria-expanded="true">
                      <span class="btn-fill" data-fill></span>
                      <span class="btn-text">
                        {%- liquid
                          render 'icon', icon: 'filter'
                          echo 'collections.filtering.filter_hide_button' | t
                        -%}
                      </span>
                      <span class="btn-text btn-duplicate">
                        {%- liquid
                          render 'icon', icon: 'filter'
                          echo 'collections.filtering.filter_show_button' | t
                        -%}
                        <facet-count class="facet-count flex items-center justify-center text-xs font-medium rounded-full"{% if filter_count == 0 %} hidden{% endif %}>{{ filter_count }}</facet-count>
                      </span>
                    </button>
                  </div>
                {%- endif -%}
              {%- endif -%}

              <p id="ProductCount" class="grow text-base lg:text-lg" role="status">
                {%- liquid
                  if search.results_count
                    echo 'general.search.results_with_count' | t: terms: search.terms, count: search.results_count
                  elsif search.products_count == search.all_products_count
                    echo 'collections.general.product_count_simple' | t: count: search.products_count
                  else
                    echo 'collections.general.product_count' | t: product_count: search.products_count, count: search.all_products_count
                  endif
                -%}
              </p>

              {%- if show_on_model -%}
                <div class="facet-wrapper">
                  {%- if show_on_model -%}
                    <button class="link model-view" type="button" is="model-view">
                      <span class="link-text">{{ 'collections.general.show_on_model' | t }}</span>
                      <span class="link-text">{{ 'collections.general.product_view' | t }}</span>
                    </button>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if enable_sorting -%}
                {%- liquid
                  assign sort_by = search.sort_by | default: search.default_sort_by
                  for option in search.sort_options
                    if option.value == sort_by
                      assign sort_by_name = option.name
                      break
                    endif
                  endfor
                -%}
                <div class="facet-sorting inline-flex items-center gap-6" id="SortByContainer">
                  {%- unless show_on_model -%}
                    <span>{{ 'collections.sorting.sort_by_label' | t }}</span>
                  {%- endunless -%}
                  <facet-sort class="sort-wrapper relative">
                    <hover-element class="button button--{{ buttons_style }} sort-by whitespace-nowrap overflow-hidden z-3">
                      <span class="btn-fill" data-fill></span>
                      <div class="btn-text">
                        <span class="sort-header flex items-center justify-center gap-5 relative w-full">
                          <span class="sort-selection">{{ sort_by_name | escape }}</span>
                          <span class="sort-title text-sm uppercase absolute left-0 opacity-0 tracking-widest">{{ 'collections.sorting.sort_button' | t }}</span>
                          <span class="sort-close flex items-center justify-center rounded-full">
                            {%- render 'icon', icon: 'close', size: 'sm' -%}
                          </span>
                        </span>
                        <ul class="sort-listbox text-left grid gap-2 absolute left-0 opacity-0 invisible w-full h-auto">
                          {%- for option in search.sort_options -%}
                            <li class="opacity-0 relative">
                              <input id="SortBy-{{ option.value }}" class="sr-only" name="sort_by" type="radio" value="{{ option.value }}"{% if option.value == sort_by %} checked{% endif %} />
                              <label for="SortBy-{{ option.value }}" class="reversed-link text-xl">{{ option.name | escape }}</label>
                            </li>
                          {%- endfor -%}
                        </ul>
                      </div>
                    </hover-element>
                  </facet-sort>
                </div>
              {%- endif -%}
            </div>
            {%- if section.settings.rounded -%}
              {%- render 'corner', dir: 'bottom', border: true, prefix: 'collection' -%}
            {%- else -%}
              <span class="collection__cutout cutout opacity-0 absolute left-0 top-100 w-full pointer-events-none"></span>
            {%- endif -%}
          </facets-topbar>
        {%- endif -%}
      {%- endif -%}

      {%- liquid
        if enable_filtering
          render 'facets-active', results: search, enable_color_swatches: section.settings.filter_color_swatches, filter_count: filter_count
        endif
      -%}

      <div class="collection__content flex">
        {%- if enable_filtering and filter_type == 'sidebar' and search.results_count > 0 -%}
          <div class="hidden xl:block" id="FacetFiltersContainer">
            <sticky-element class="facets__scroll block xl:sticky top-0" aria-controls="FacetsTopbar-{{ section.id }}">
              {%- render 'facets',
                context: 'sidebar',
                results: search,
                collapsed: section.settings.filter_collapsed,
                enable_filtering: enable_filtering,
                enable_sorting: false,
                enable_color_swatches: section.settings.filter_color_swatches,
                section_id: section.id
              -%}
            </sticky-element>
          </div>
        {%- endif -%}

        <div class="flex flex-col gap-12 grow" id="ProductGridContainer">
          {%- if search.performed and search.results.size == 0 -%}
            <div class="empty-state flex flex-col items-center justify-center text-center gap-6">
              {%- render 'icon', icon: 'empty', size: 'xxxl' -%}
              <div class="flex flex-col items-center gap-4">
                <p class="heading leading-none tracking-tight">
                  {{- 'general.search.no_results' | t: terms: search.terms | replace: '*', '' -}}
                </p>
                <p>{{ 'general.search.user_different_terms' | t }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- if search.results_count > 0 -%}
            <div class="card-grid card-grid--{{ section.settings.columns }} mobile:card-grid--{{ section.settings.columns_mobile }} grid relative">
              {%- for item in search.results -%}
                {%- liquid
                  for block in section.blocks
                    if block.type == 'promotion' or block.type == 'promotion_video'
                      if forloop.parentloop.index != block.settings.position
                        continue
                      endif

                      render 'promotion-card', block: block
                    endif
                  endfor

                  assign lazy_load = false
                  if forloop.index > 2
                    assign lazy_load = true
                  endif
                -%}

                {%- case item.object_type -%}
                  {%- when 'product' -%}
                    {%- render 'product-card',
                      product: item,
                      product_id: item.id,
                      section_id: section.id,
                      lazy_load: lazy_load,
                      image_ratio: settings.product_image_ratio,
                      image_fill: settings.product_image_fill,
                      show_secondary_image: settings.product_secondary_image,
                      show_vendor: settings.product_vendor,
                      show_rating: settings.product_rating,
                      show_color_swatches: settings.product_color_swatches,
                      show_countdown: settings.product_countdown,
                      show_quick_add: settings.product_quick_add,
                      show_quick_view: settings.product_quick_view,
                      vertical_badges: settings.product_vertical_badges,
                      show_sold_out: settings.product_sold_out,
                      show_save_amount: settings.product_save_amount,
                      save_type: settings.product_save_type,
                      show_icon_list: settings.product_icon_list,
                      show_on_model: show_on_model
                    -%}

                  {%- when 'article' -%}
                    {%- liquid
                      assign article = item
                      assign featured_media = article.image
                      assign image_ratio = settings.product_image_ratio
                      assign image_fill = settings.product_image_fill

                      assign split_1 = article.url | split: '/blogs/'
                      assign split_2 = split_1[1] | split: '/'
                      assign blog_handle = split_2[0] | strip
                      assign blog = blogs[blog_handle]
                    -%}
                    <div class="card article-card product-card product-card--{{ settings.card_style }}{% if settings.card_border_thickness > 0 %} product-card--thickness{% endif %}{% unless featured_media %} no-media{% endunless %} flex flex-col leading-none relative overflow-hidden">
                      <div class="product-card__media relative h-auto">
                        {%- if section.settings.show_post_tags and article.tags.size > 0 -%}
                          <div class="badges z-2 absolute grid gap-3">
                            {%- if article.metafields.theme.tag_color.value != blank and article.metafields.theme.tag_background.value != blank -%}
                              {%- capture badge_style -%}
                                --badge-foreground: rgb({{ article.metafields.theme.tag_color.value.rgb }});--badge-background: rgb({{ article.metafields.theme.tag_background.value.rgb }});
                              {%- endcapture -%}
                            {%- endif -%}
                            
                            {%- for tag in article.tags -%}
                              <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="badge{% if badge_style %} badge--custom{% endif %} font-medium leading-none rounded-full"{% if badge_style %} style="{{ badge_style }}"{% endif %}>{{ tag }}</a>
                            {%- endfor -%}
                          </div>
                        {%- endif -%}

                        {%- if featured_media -%}
                          <a class="block relative media media--{{ image_ratio }}{% unless image_fill %} media--contain{% endunless %} overflow-hidden" href="{{ article.url }}">
