                              {{- item.title | escape -}}
                            </a>
                          </p>
                        </div>
                      </div>
                    </div>

                {%- endcase -%}
              {%- endfor -%}
            </div>

            {%- liquid
              if paginate.pages > 1
                render 'pagination', paginate: paginate, mode: section.settings.pagination
              endif
            -%}
          {%- endif -%}
        </div>
      </div>
