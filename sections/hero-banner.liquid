{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slideshow.css' | asset_url | stylesheet_tag }}

{% if section.settings.slide_height == 'adapt_image'%}
  {% style %}
  .adapt_to-image {
  height: 100 !important;
  width: 100% !important;
  position: relative !important;
  }
  .adapt_to-image > img {
  height: 100 !important;
  width: 100% !important;
  position: relative !important;
  }
  {% endstyle %}
{% endif %}


<slideshow-component
  class="slider-mobile-gutter{% if section.settings.layout == 'grid' %} page-width{% endif %}{% if section.settings.show_text_below %} mobile-text-below{% endif %}"
  role="region" aria-roledescription="{{ 'sections.slideshow.carousel' | t }}"
  aria-label="{{ section.settings.accessibility_info | escape }}">


  <a {% if section.settings.link %} href="{{ section.settings.link }}" {% endif %}
    class="slide-link slideshow banner banner--{{ section.settings.slide_height }} 
grid grid--1-col slider slider--everywhere{% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}
{% if section.settings.image == blank %} slideshow--placeholder{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}" id="Slider-{{ section.id }}"
    aria-live="polite" aria-atomic="true" data-autoplay="{{ section.settings.auto_rotate }}"
    data-speed="{{ section.settings.change_slides_speed }}">

<style>
  #Slide-{{ section.id }}-{{ forloop.index }} .banner__media::after {
    opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
  }
  #Slide-{{ section.id }}-{{ forloop.index }} .slideshow__text-wrapper .slideshow__text h2, 
  #Slide-{{ section.id }}-{{ forloop.index }} .slideshow__text-wrapper .slideshow__text p {
    color: {{ section.settings.text_color }};
  }
</style>

    <div class="slideshow__slide grid__item grid--1-col slider__slide" id="Slide-{{ section.id }}-{{ forloop.index }}"
      {{ block.shopify_attributes }} role="group" aria-roledescription="{{ 'sections.slideshow.slide' | t }}"
      aria-label="{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}" tabindex="-1">

      {% comment %} <!-- Desktop specific image --> {% endcomment %}
      <div
        class=" {% if section.settings.slide_height == 'adapt_image'%} adapt_to-image {% endif %}
      slideshow__media banner__media media desktop-only{% if section.settings.image == blank %} placeholder{% endif %}{% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}"
        {% if section.settings.slide_height == 'adapt_image'%} style="
             height: 100; 
             width: 100%;
             position: relative;
           " {% endif %}>
        {%- if section.settings.image -%}
        {%- liquid
              assign height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio | round
              if section.settings.image_behavior == 'ambient'
                assign sizes = '120vw'
                assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
              else
                assign sizes = '100vw'
                assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
              endif
            -%}
        {{
              section.settings.image
              | image_url: width: 3840
              | image_tag: loading: 'lazy', height: height, sizes: sizes, widths: widths
            }}
        {%- else -%}
        {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
        {%- if placeholder_slide == 1 -%}
        {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- else -%}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        {%- endif -%}
      </div>


      {% comment %} <!-- Mobile specific image --> {% endcomment %}
      {% if section.settings.mobile_image == blank %}
      {% assign mobile_image = section.settings.image %}
      {% else %}
      {% assign mobile_image = section.settings.mobile_image %}
      {% endif %}
      <div
        class=" {% if section.settings.slide_height == 'adapt_image'%} adapt_to-image {% endif %}
          slideshow__media banner__media media mobile-only{% if mobile_image == blank %} placeholder{% endif %}
        {% if section.settings.image_behavior != 'none' %} animate--{{ section.settings.image_behavior }}{% endif %}">
        {%- if mobile_image -%}
        {%- liquid
      assign height = mobile_image.width | divided_by: mobile_image.aspect_ratio | round
      if section.settings.image_behavior == 'ambient'
        assign sizes = '120vw'
        assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
      else
        assign sizes = '100vw'
        assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
      endif
    -%}
        {{
      mobile_image
      | image_url: width: 3840
      | image_tag: loading: 'lazy', height: height, sizes: sizes, widths: widths
    }}
        {%- else -%}
        {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
        {%- if placeholder_slide == 1 -%}
        {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- else -%}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        {%- endif -%}
      </div>

      {% comment %} the slide content {% endcomment %}
      <div
        class="slideshow__text-wrapper banner__content banner__content--{{ section.settings.box_align }} page-width banner--desktop-transparent {% if settings.animations_reveal_on_scroll and forloop.index == 1 %} scroll-trigger animate--slide-in{% endif %}"
        {%- if section.settings.slide_height == 'adapt_image'-%} style="
      position: absolute;
      " {%- endif -%}>
        <div
          class="slideshow__text banner__box content-container content-container--full-width-mobile  gradient slideshow__text--{{ section.settings.text_alignment }} slideshow__text-mobile--{{ section.settings.text_alignment_mobile }}">
          {%- if section.settings.heading != blank -%}
          <h2 class="banner__heading inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
          <div class="banner__text rte" {{ block.shopify_attributes }}>
            <p>{{ section.settings.subheading }}</p>
          </div>
          {%- endif -%}

          {%- if section.settings.button_label != blank  and section.settings.plain_text_link-%}
          {% comment %} USE BUTTON STYLES LINK {% endcomment %}
          {% style %}
          #Slide-{{ section.id }}-{{ forloop.index }} .banner__buttons {
          color: {{ section.settings.button_text_color }};
          margin-top: 1rem;
          }
          #Slide-{{ section.id }}-{{ forloop.index }} .banner__buttons {
          position: relative;
          display: inline-block; /* Make sure this is inline-block or block */
          padding-bottom: 5px ; /* Adjust padding as needed */
          text-align: center;
          text-decoration: none;
          /* Other styles */
          }

          #Slide-{{ section.id }}-{{ forloop.index }} .banner__buttons::after {
          content: '';
          position: absolute;
          bottom: 0;
          left: 50%;
          width: 0;
          height: 2px; /* Adjust thickness of underline */
          background-color: {{ section.settings.button_text_color }}; /* Color of underline */
          transition: width 0.3s ease 0s, left 0.3s ease 0s;
          }

          #Slide-{{ section.id }}-{{ forloop.index }}:hover .banner__buttons::after {
          width: 100%;
          left: 0;
          }
          {% endstyle %}
          <div class="banner__buttons">
            {{- section.settings.button_label | escape -}}
          </div>

          {% comment %} USE BUTTON STYLES LINK {% endcomment %}
          {% else %}
          {% style %}
          /* Primary button styles */
          #Slide-{{ section.id }}-{{ forloop.index }} .hero-button.button--primary {
          color: {{ section.settings.button_text_color }};
          background-color: {{ section.settings.button_bg }};
          }
          #Slide-{{ section.id }}-{{ forloop.index }} .banner__buttons .hero-button.button--primary::after {
          box-shadow: 0 0 0 1px {{ section.settings.button_bg }};
          transition: all 0.3s ease;
          }
          #Slide-{{ section.id }}-{{ forloop.index }} .banner__buttons .hero-button.button--primary:hover::after {
          box-shadow: 0 0 0 2px {{ section.settings.button_bg }};
          transition: all 0.3s ease;
          }

          /* Secondary button styles */
          #Slide-{{ section.id }}-{{ forloop.index }} .hero-button.button--secondary {
          color: {{ section.settings.button_text_color }};
          }
          #Slide-{{ section.id }}-{{ forloop.index }} .banner__buttons .hero-button.button--secondary::after {
          box-shadow: 0 0 0 1px {{ section.settings.button_text_color }};
          transition: all 0.3s ease;
          }
          #Slide-{{ section.id }}-{{ forloop.index }} .banner__buttons .hero-button.button--secondary:hover::after {
          box-shadow: 0 0 0 2px {{ section.settings.button_text_color }};
          transition: all 0.3s ease;
          }
          {% endstyle %}
          <div class="banner__buttons">
            <div {% if section.settings.link %} href="{{ section.settings.link }}" {% else %} role="link"
              aria-disabled="true" {% endif %}
              class="button hero-button {% if section.settings.button_style_secondary %}button--secondary{% else %}button--primary{% endif %}">
              {{- section.settings.button_label | escape -}}
            </div>
          </div>

          {%- endif -%}

        </div>
      </div>
      {% comment %} the slide content {% endcomment %}
    </div>
  </a>



</slideshow-component>

{%- if request.design_mode -%}
<script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% schema %}
{
"name": "Hero banner",
"class": "section",
"tag": "section",
"disabled_on": {
"groups": ["header", "footer"]
},
"settings": [
{
"type": "select",
"id": "layout",
"options": [
{
"value": "full_bleed",
"label": "t:sections.slideshow.settings.layout.options__1.label"
},
{
"value": "grid",
"label": "t:sections.slideshow.settings.layout.options__2.label"
}
],
"default": "full_bleed",
"label": "t:sections.slideshow.settings.layout.label"
},
{
"type": "select",
"id": "slide_height",
"options": [
{
"value": "adapt_image",
"label": "adapt to image"
},
{
"value": "small",
"label": "t:sections.slideshow.settings.slide_height.options__2.label"
},
{
"value": "medium",
"label": "t:sections.slideshow.settings.slide_height.options__3.label"
},
{
"value": "large",
"label": "t:sections.slideshow.settings.slide_height.options__4.label"
},
{
"value": "x-large",
"label": "x-large"
}
],
"default": "large",
"label": "Desktop image height"
},
{
"type": "header",
"content": "Images"
},
{
"type": "image_picker",
"id": "image",
"label": "t:sections.slideshow.blocks.slide.settings.image.label",
"info": "Recommended 4086 x 2048 | 2481 x 1241 | file type: webp for speed"
},
{
"type": "image_picker",
"id": "mobile_image",
"label": "mobile specific images",
"info": "Recommended 768 x 1384 | file type: webp for speed"
},
{
"type": "url",
"id": "link",
"label": "Image Link"
},
{
"type": "header",
"content": "Hero content"
},
{
"type": "inline_richtext",
"id": "heading",
"default": "Image slide",
"label": "t:sections.slideshow.blocks.slide.settings.heading.label"
},
{
"type": "select",
"id": "heading_size",
"options": [
{
"value": "h2",
"label": "t:sections.all.heading_size.options__1.label"
},
{
"value": "h1",
"label": "t:sections.all.heading_size.options__2.label"
},
{
"value": "h0",
"label": "t:sections.all.heading_size.options__3.label"
}
],
"default": "h1",
"label": "t:sections.all.heading_size.label"
},
{
"type": "inline_richtext",
"id": "subheading",
"default": "Tell your brand's story through images",
"label": "t:sections.slideshow.blocks.slide.settings.subheading.label"
},
{
"type": "header",
"content": "Button Settings"
},
{
"type": "text",
"id": "button_label",
"default": "Button label",
"label": "t:sections.slideshow.blocks.slide.settings.button_label.label",
"info": "t:sections.slideshow.blocks.slide.settings.button_label.info"
},
{
"type": "checkbox",
"id": "plain_text_link",
"label": "Use plain text link",
"default": true,
"info": "uncheck to use button styles"
},
{
"type": "color",
"id": "button_text_color",
"label": "button text color",
"default": "#fff"
},
{
"type": "color",
"id": "button_bg",
"label": "button background color",
"default": "#000"
},
{
"type": "checkbox",
"id": "button_style_secondary",
"label": "t:sections.slideshow.blocks.slide.settings.secondary_style.label",
"default": false
},
{
"type": "select",
"id": "box_align",
"options": [
{
"value": "top-left",
"label": "t:sections.slideshow.blocks.slide.settings.box_align.options__1.label"
},
{
"value": "top-center",
"label": "t:sections.slideshow.blocks.slide.settings.box_align.options__2.label"
},
{
"value": "top-right",
"label": "t:sections.slideshow.blocks.slide.settings.box_align.options__3.label"
},
{
"value": "middle-left",
"label": "t:sections.slideshow.blocks.slide.settings.box_align.options__4.label"
},
{
"value": "middle-center",
"label": "t:sections.slideshow.blocks.slide.settings.box_align.options__5.label"
},
{
"value": "middle-right",
"label": "t:sections.slideshow.blocks.slide.settings.box_align.options__6.label"
},
{
"value": "bottom-left",
"label": "t:sections.slideshow.blocks.slide.settings.box_align.options__7.label"
},
{
"value": "bottom-center",
"label": "t:sections.slideshow.blocks.slide.settings.box_align.options__8.label"
},
{
"value": "bottom-right",
"label": "t:sections.slideshow.blocks.slide.settings.box_align.options__9.label"
}
],
"default": "middle-center",
"label": "t:sections.slideshow.blocks.slide.settings.box_align.label",
"info": "t:sections.slideshow.blocks.slide.settings.box_align.info"
},
{
"type": "select",
"id": "text_alignment",
"options": [
{
"value": "left",
"label": "t:sections.slideshow.blocks.slide.settings.text_alignment.option_1.label"
},
{
"value": "center",
"label": "t:sections.slideshow.blocks.slide.settings.text_alignment.option_2.label"
},
{
"value": "right",
"label": "t:sections.slideshow.blocks.slide.settings.text_alignment.option_3.label"
}
],
"default": "center",
"label": "t:sections.slideshow.blocks.slide.settings.text_alignment.label"
},
{
"type": "range",
"id": "image_overlay_opacity",
"min": 0,
"max": 100,
"step": 10,
"unit": "%",
"label": "t:sections.slideshow.blocks.slide.settings.image_overlay_opacity.label",
"default": 0
},
{
"type": "color",
"id": "text_color",
"label": "text color",
"default": "#fff"
},
{
"type": "header",
"content": "t:sections.slideshow.settings.mobile.content"
},
{
"type": "select",
"id": "text_alignment_mobile",
"options": [
{
"value": "left",
"label": "t:sections.slideshow.blocks.slide.settings.text_alignment_mobile.options__1.label"
},
{
"value": "center",
"label": "t:sections.slideshow.blocks.slide.settings.text_alignment_mobile.options__2.label"
},
{
"value": "right",
"label": "t:sections.slideshow.blocks.slide.settings.text_alignment_mobile.options__3.label"
}
],
"default": "center",
"label": "t:sections.slideshow.blocks.slide.settings.text_alignment_mobile.label"
},
{
"type": "header",
"content": "t:sections.slideshow.settings.accessibility.content"
},
{
"type": "text",
"id": "accessibility_info",
"label": "t:sections.slideshow.settings.accessibility.label",
"info": "Describe the image for customers using screen readers",
"default": "Image about our brand"
}
],
"presets": [
{
"name": "Hero banner"
}
]
}
{% endschema %}