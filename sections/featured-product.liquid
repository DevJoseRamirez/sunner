                  assign rating_block = section.blocks | where: "type", "rating" | first
                -%}
                <div class="product__title grid gap-3{% if price_block == blank and block.settings.show_price %} with-price{% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %} with-price--on-sale{% endif %}{% endif %}" {{ block.shopify_attributes }}>
                  <h1 class="heading leading-none {{ block.settings.title_size }} mobile:{{ block.settings.title_size_mobile }} col-span-full">
                    <split-words class="split-words js-invisible block" >{{ product.title }}</split-words>
                  </h1>
  
                  {%- if price_block == blank and block.settings.show_price -%}
                    <div id="Price-{{ section.id }}-{{ product.id }}" class="product__price">
                      {%- render 'product-price', product: product, placeholder: placeholder, use_variant: true, class: 'flex flex-wrap items-baseline gap-2 lg:flex-col xl:items-end lg:gap-1d5' -%}
                      
                      {%- if product.quantity_price_breaks_configured? -%}
                        <div class="text-opacity text-sm font-medium leading-tight" id="VolumeNote-{{ section.id }}-{{ product.id }}">
                          {{- 'products.volume_pricing.note' | t -}}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
  
                  {%- liquid
                    if rating_block == blank and block.settings.show_rating
                      render 'product-rating', product: product
                    endif
                  -%}
                </div>
  
