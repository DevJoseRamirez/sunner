                    {{ form | payment_terms }}
                  {%- endform -%}
                {%- endif -%}

              {%- when 'price' -%}
                <div class="product__price grid gap-3" {{ block.shopify_attributes }}>
                  <div class="no-js-hidden" id="Price-{{ section.id }}-{{ product.id }}">
                    {%- render 'product-price', product: product, placeholder: placeholder, use_variant: true, class: 'flex flex-wrap items-baseline gap-2 lg:gap-1d5' -%}
                    
                    {%- if product.quantity_price_breaks_configured? -%}
                      <div class="text-opacity text-sm font-medium leading-tight" id="VolumeNote-{{ section.id }}-{{ product.id }}">
