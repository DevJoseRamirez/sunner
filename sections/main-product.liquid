<script>
(function () {
  const isMobile = () => window.matchMedia('(max-width: 1023px)').matches;

  const norm = (s) => String(s || '')
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .trim();

  const tokenAliases = (token) => {
    const t = norm(token);
    const base = [t];
    const map = {
      tea: ['tea', 'offwhite', 'white', 'cream', 'ivory'],
      soil: ['soil', 'brown', 'tan', 'khaki', 'earth'],
      jet: ['jet', 'black', 'charcoal']
    };
    return Array.from(new Set([...(map[t] || base), ...base]));
  };

  const getInputFromTarget = (t) => {
    if (!t) return null;

    if (t.matches && t.matches('input[type="radio"][data-option-value]')) return t;

    const label = t.closest && t.closest('label[for]');
    if (label) {
      const id = label.getAttribute('for');
      if (id) return document.getElementById(id);
    }

    const li = t.closest && t.closest('li');
    if (li) {
      const input = li.querySelector && li.querySelector('input[type="radio"][data-option-value]');
      if (input) return input;
    }

    return null;
  };

  const findGallery = (input) => {
    const productInfo = input.closest('product-info');
    const section = productInfo ? productInfo.closest('section, [id^="shopify-section-"]') : null;
    return (section ? section.querySelector('media-gallery[id^="ProductGallery-"]') : null)
      || document.querySelector('media-gallery[id^="ProductGallery-"]');
  };

  const getScrollContainer = (gallery) => {
    const slider = gallery.querySelector('slider-element[id^="SliderGallery-"]');
    if (!slider) return null;

    const list = slider.querySelector('.product__media-list');
    if (!list) return null;

    const style = window.getComputedStyle(list);
    const canScroll = list.scrollWidth > list.clientWidth;

    if (canScroll && (style.overflowX === 'auto' || style.overflowX === 'scroll' || style.overflowX === 'hidden')) {
      return list;
    }

    const sliderStyle = window.getComputedStyle(slider);
    const sliderCanScroll = slider.scrollWidth > slider.clientWidth;
    if (sliderCanScroll && (sliderStyle.overflowX === 'auto' || sliderStyle.overflowX === 'scroll' || sliderStyle.overflowX === 'hidden')) {
      return slider;
    }

    return list;
  };

  const getMediaItems = (gallery) => {
    const slider = gallery.querySelector('slider-element[id^="SliderGallery-"]');
    const list = slider ? slider.querySelector('.product__media-list') : null;
    if (!list) return [];
    return Array.from(list.querySelectorAll('.product__media'));
  };

  const mediaMatchesToken = (mediaEl, aliases) => {
    const imgs = Array.from(mediaEl.querySelectorAll('img'));
    const haystacks = [];

    imgs.forEach((img) => {
      if (img.currentSrc) haystacks.push(img.currentSrc);
      if (img.getAttribute('src')) haystacks.push(img.getAttribute('src'));
      if (img.getAttribute('srcset')) haystacks.push(img.getAttribute('srcset'));
      if (img.getAttribute('alt')) haystacks.push(img.getAttribute('alt'));
    });

    const joined = norm(haystacks.join(' '));
    return aliases.some((a) => joined.includes(norm(a)));
  };

  const scrollToMedia = (gallery, token) => {
    const aliases = tokenAliases(token);
    const items = getMediaItems(gallery);
    if (!items.length) return false;

    const target = items.find((el) => mediaMatchesToken(el, aliases));
    if (!target) return false;

    const container = getScrollContainer(gallery);
    if (!container) return false;

    const cRect = container.getBoundingClientRect();
    const tRect = target.getBoundingClientRect();
    const left = container.scrollLeft + (tRect.left - cRect.left);

    container.scrollTo({ left, behavior: 'smooth' });
    return true;
  };

  const forcePick = (input) => {
    if (!input || input.disabled) return false;
    input.checked = true;
    input.dispatchEvent(new Event('input', { bubbles: true }));
    input.dispatchEvent(new Event('change', { bubbles: true }));
    return true;
  };

  document.addEventListener('click', (e) => {
    const input = getInputFromTarget(e.target);
    if (!input) return;

    e.preventDefault();
    e.stopPropagation();

    const ok = forcePick(input);
    if (!ok) return;

    if (!isMobile()) return;

    const gallery = findGallery(input);
    if (!gallery) return;

    const token = input.value;
    scrollToMedia(gallery, token);
  }, true);
})();
</script>




