                        background-size: 180% 180%, 160% 160%, 200% 200%;
                        filter: blur(8px); /* soft, no sharp edges */
                        animation: header-color-drift 18s ease-in-out infinite;
                      }
                      .header::before {
                    content: '';
                    position: absolute;
                    inset: -20%;
                    z-index: 0;
                    pointer-events: none;
                    background:
                      radial-gradient(45% 60% at 20% 30%, rgba(40, 130, 160, 0.75) 0%, transparent 60%),
                      radial-gradient(40% 55% at 70% 25%, rgba(120, 200, 225, 0.65) 0%, transparent 60%),
