{% comment %} Water refraction filter — invisible, defines #liquid-distortion {% endcomment %}
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <filter id="liquid-distortion" x="0%" y="0%" width="100%" height="100%">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.009 0.014"
        numOctaves="2"
        seed="4"
        result="noise"
      >
        <animate
          attributeName="baseFrequency"
          dur="30s"
          values="0.009 0.014; 0.013 0.010; 0.009 0.014"
          repeatCount="indefinite"
          calcMode="spline"
          keySplines="0.4 0 0.6 1; 0.4 0 0.6 1"
        />
      </feTurbulence>
      <feDisplacementMap
        in="SourceGraphic"
        in2="noise"
        scale="20"
        xChannelSelector="R"
        yChannelSelector="G"
      />
    </filter>
  </defs>
</svg>

{%- liquid
  assign header_layout = section.settings.header_layout
  assign main_menu = section.settings.menu
  assign link_count = main_menu.links.size

  if header_layout == 'center-split'
    assign link_count = link_count | divided_by: 2
  endif

  assign main_menu_class = 'lg:justify-start'
  case header_layout
    when 'center-split'
      assign main_menu_class = 'lg:justify-end'
    when 'center'
      assign main_menu_class = 'lg:justify-center'
  endcase

  assign show_toggle = false
  if header_layout == 'center'
    assign show_toggle = true
  endif

  render 'header-drawer', section: section
-%}

<header
  data-section-id="{{ section.id }}"
  class="header header--{{ header_layout }} mobile:header--{{ section.settings.logo_position_mobile }} page-width{% if section.settings.full_width %} page-width--full{% endif %} section{% if section.settings.rounded %} section--rounded{% endif %} section--padding grid items-center z-20 relative w-full"
  {% if section.settings.sticky_header_type != 'none' %}
    is="sticky-header"
    data-sticky-type="{{ section.settings.sticky_header_type }}"
  {% else %}
    is="custom-header"
  {% endif %}
>
  {%- liquid
    render 'header-icons', section: section, show_search: true, show_hamburger: true, show_toggle: show_toggle, context: 'start'

    unless header_layout == 'center-left' or header_layout == 'center-split'
      render 'header-logo', logo_h1: section.settings.logo_h1
    endunless

    if header_layout == 'center'
      render 'header-icons', section: section, show_search: true, show_account: true, show_cart: true, show_hamburger: true, context: 'end'
    endif
  -%}

  <div
    class="header__navigation hidden lg:flex lg:gap-5 {{ main_menu_class }}"
    {% if header_layout == 'center' %}
      id="MenuToggle"
    {% endif %}
  >
    <nav class="header__menu hidden lg:flex" role="navigation" aria-label="Primary">
      {%- render 'header-nav-desktop', section: section, main_menu: main_menu, limit: link_count, context: 'start' -%}
    </nav>
  </div>

  {%- if header_layout == 'center-left' or header_layout == 'center-split' -%}
    {%- render 'header-logo', logo_h1: section.settings.logo_h1 -%}
  {%- endif -%}

  {%- if header_layout == 'center-split' -%}
    <div class="header__navigation header__navigation--split hidden lg:flex lg:gap-5 lg:justify-start">
      <nav class="header__menu hidden lg:flex" role="navigation" aria-label="Secondary">
        {%- render 'header-nav-desktop', section: section, main_menu: main_menu, offset: link_count, context: 'end' -%}
      </nav>
    </div>
  {%- endif -%}

  {%- unless header_layout == 'center' -%}
    {%- render 'header-icons',
      section: section,
      show_search: true,
      show_account: true,
      show_cart: true,
      show_hamburger: true,
      context: 'end'
    -%}
  {%- endunless -%}

  {%- if section.settings.rounded -%}
    {%- render 'corner', dir: 'bottom', border: true, prefix: 'header' -%}
  {%- else -%}
    <span class="header__cutout cutout opacity-0 absolute left-0 top-100 w-full pointer-events-none"></span>
  {%- endif -%}
</header>

{%- liquid
  assign current_path = request.path | downcase
  assign hide_subcollections = false
  if current_path contains '/collections' or current_path contains '/collection' or current_path contains '/products' or current_path contains '/product'
    assign hide_subcollections = true
  endif
-%}

{% unless hide_subcollections %}
  {% if linklists.subcollections and linklists.subcollections.links.size > 0 %}
    <div class="subcollections-bar w-full border-t border-b py-3">
      <nav class="subcollections-nav page-width">
        <ul class="flex gap-5">
          {% for link in linklists.subcollections.links %}
            <li>
              <a href="{{ link.url }}" class="subcollections-link menu__item">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </nav>
    </div>
  {% endif %}
{% endunless %}

{%- if section.settings.hover_menu -%}
  <span class="overlay opacity-0 z-1 fixed left-0 w-full pointer-events-none"></span>
{%- else -%}
  <overlay-element class="overlay opacity-0 z-1 fixed left-0 w-full pointer-events-none"></overlay-element>
{%- endif -%}

{%- if request.design_mode -%}
  <script>
    document.documentElement.style.setProperty(
      '--header-height',
      document.getElementById('shopify-section-{{ section.id }}').getBoundingClientRect().height.toFixed(1) + 'px'
    );
  </script>
{%- endif -%}

<script>
  'use strict';
  (function () {
    var bar = document.querySelector('.subcollections-bar');
    if (!bar) return;

    var links = Array.prototype.slice.call(bar.querySelectorAll('.subcollections-link'));
    if (!links.length) return;

    var KEY = 'subcollection_active';
    var isHomepage = window.location.pathname === '/' || window.location.pathname === '/index.html';

    function setActive(title) {
      var t = (title || '').trim().toUpperCase();
      links.forEach(function (link) {
        var match = link.textContent.trim().toUpperCase() === t;
        link.classList.toggle('is-active', match);
        if (match) scrollToLink(link);
      });
    }

    function scrollToLink(el) {
      var nav = bar.querySelector('.subcollections-nav');
      if (nav) nav.scrollTo({ left: el.offsetLeft - nav.offsetLeft - 40, behavior: 'smooth' });
    }

    links.forEach(function (link) {
      link.addEventListener('click', function () {
        try {
          sessionStorage.setItem(KEY, this.textContent.trim());
        } catch (e) {}
      });
    });

    if (isHomepage) {
      try {
        sessionStorage.removeItem(KEY);
      } catch (e) {}
      setActive('ALL');
    } else {
      try {
        var saved = sessionStorage.getItem(KEY);
        if (saved) setActive(saved);
      } catch (e) {}
    }
  })();
</script>

