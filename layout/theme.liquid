<script>
(function () {
  var PATCHED = false;

  function isHome() {
    var p = window.location.pathname || "/";
    return p === "/" || p === "" || p === "/index" || p === "/index.html";
  }

  function norm(s) {
    return String(s || "").replace(/\s+/g, " ").trim().toLowerCase();
  }

  function getBar() {
    return document.querySelector(".subcollections-bar");
  }

  function getLinks(bar) {
    if (!bar) return [];
    return Array.prototype.slice.call(bar.querySelectorAll(".subcollections-link"));
  }

  function getAllMeta() {
    var bar = getBar();
    var links = getLinks(bar);
    if (!links.length) return null;

    var allLink = null;
    for (var i = 0; i < links.length; i++) {
      if (norm(links[i].textContent) === "all") { allLink = links[i]; break; }
    }
    if (!allLink) return null;

    var href = String(allLink.getAttribute("href") || "");
    var idx = links.indexOf(allLink);

    return { href: href, index: idx, text: "all" };
  }

  function applyDomAllActive() {
    if (!isHome()) return;
    var bar = getBar();
    if (!bar) return;

    var links = getLinks(bar);
    if (!links.length) return;

    var allLink = null;
    for (var i = 0; i < links.length; i++) {
      if (norm(links[i].textContent) === "all") { allLink = links[i]; break; }
    }
    if (!allLink) return;

    for (var k = 0; k < links.length; k++) {
      links[k].classList.remove("is-active", "active");
      links[k].removeAttribute("aria-current");
    }
    allLink.classList.add("is-active");
    allLink.setAttribute("aria-current", "page");
  }

  function looksRelevantKey(key) {
    return /sub|collection|collections|tab|active|nav|menu|filter|highlight|selected/i.test(String(key || ""));
  }

  function patchJsonValue(v, allMeta) {
    var s = String(v || "");
    var obj;
    try { obj = JSON.parse(s); } catch (e) { return null; }
    if (!obj || typeof obj !== "object") return null;

    var changed = false;

    if (typeof obj.activeIndex === "number" && obj.activeIndex !== allMeta.index) {
      obj.activeIndex = allMeta.index;
      changed = true;
    }
    if (typeof obj.selectedIndex === "number" && obj.selectedIndex !== allMeta.index) {
      obj.selectedIndex = allMeta.index;
      changed = true;
    }

    var allHref = allMeta.href;
    var allText = allMeta.text;

    var keys = ["active", "activeTab", "activeHandle", "activeCollection", "selected", "selectedTab", "selectedHandle", "selectedCollection", "current", "currentTab"];
    for (var i = 0; i < keys.length; i++) {
      var k = keys[i];
      if (typeof obj[k] === "string") {
        var val = norm(obj[k]);
        if (val && val !== allText && val !== norm(allHref)) {
          obj[k] = allHref || "all";
          changed = true;
        }
      }
    }

    if (!changed) return null;
    try { return JSON.stringify(obj); } catch (e2) { return null; }
  }

  function normalizeValueToAll(value, allMeta) {
    var s = String(value || "");
    var patchedJson = patchJsonValue(s, allMeta);
    if (patchedJson) return patchedJson;

    var vNorm = norm(s);
    if (!vNorm) return s;

    if (vNorm === "all") return allMeta.href || s;

    var bar = getBar();
    var links = getLinks(bar);
    for (var i = 0; i < links.length; i++) {
      var t = norm(links[i].textContent);
      if (t && vNorm.indexOf(t) !== -1 && t !== "all") {
        return allMeta.href || "all";
      }
      var href = String(links[i].getAttribute("href") || "");
      if (href && s.indexOf(href) !== -1 && href !== allMeta.href) {
        return allMeta.href || "all";
      }
    }

    return s;
  }

  function forceStorageAll() {
    if (!isHome()) return;
    var allMeta = getAllMeta();
    if (!allMeta) return;

    var storages = [window.localStorage, window.sessionStorage];

    for (var si = 0; si < storages.length; si++) {
      var st = storages[si];
      if (!st) continue;

      var keys = [];
      for (var i = 0; i < st.length; i++) {
        var k = st.key(i);
        if (k) keys.push(k);
      }

      for (var j = 0; j < keys.length; j++) {
        var key = keys[j];
        if (!looksRelevantKey(key)) continue;

        var cur = st.getItem(key);
        if (cur == null) continue;

        var next = normalizeValueToAll(cur, allMeta);
        if (next !== cur) {
          try { st.setItem(key, next); } catch (e) {}
        }
      }
    }
  }

  function hookStorage() {
    if (PATCHED) return;
    PATCHED = true;

    function wrapStorage(st) {
      if (!st) return;

      var origSet = st.setItem.bind(st);
      var origRemove = st.removeItem.bind(st);

      st.setItem = function (key, value) {
        if (isHome() && looksRelevantKey(key)) {
          var allMeta = getAllMeta();
          if (allMeta) value = normalizeValueToAll(value, allMeta);
        }
        return origSet(key, value);
      };

      st.removeItem = function (key) {
        return origRemove(key);
      };
    }

    wrapStorage(window.localStorage);
    wrapStorage(window.sessionStorage);
  }

  function hardSync() {
    hookStorage();
    forceStorageAll();
    applyDomAllActive();

    setTimeout(function () {
      forceStorageAll();
      applyDomAllActive();
    }, 50);

    setTimeout(function () {
      forceStorageAll();
      applyDomAllActive();
    }, 250);
  }

  function bindLogo() {
    var logoLink = document.querySelector(".header__logo a.header__logo-link[href='/'], .header__logo a[href='/']");
    if (!logoLink) return;
    if (logoLink.dataset.allStorageBound === "1") return;
    logoLink.dataset.allStorageBound = "1";

    logoLink.addEventListener("click", function () {
      hardSync();
    }, { capture: true });
  }

  document.addEventListener("DOMContentLoaded", function () {
    bindLogo();
    hardSync();
  });

  window.addEventListener("pageshow", function () {
    bindLogo();
    hardSync();
  });

  window.addEventListener("popstate", function () {
    hardSync();
  });
})();
</script>


