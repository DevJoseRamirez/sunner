  <script>
(function () {
  var lockedY = null;
  var lockUntil = 0;

  function now() {
    return Date.now ? Date.now() : +new Date();
  }

  function getY() {
    return window.pageYOffset || document.documentElement.scrollTop || 0;
  }

  function setY(y) {
    window.scrollTo(0, y);
  }

  function lock() {
    lockedY = getY();
    lockUntil = now() + 1200;
  }

  function restore() {
    if (lockedY == null) return;
    if (now() > lockUntil) return;
    setY(lockedY);
  }

  function burstRestore() {
    restore();
    requestAnimationFrame(restore);
    setTimeout(restore, 0);
    setTimeout(restore, 60);
    setTimeout(restore, 180);
    setTimeout(restore, 420);
  }

  function wrapHistory(fnName) {
    if (!history || !history[fnName]) return;
    var original = history[fnName];
    history[fnName] = function () {
      var res = original.apply(this, arguments);
      if (lockedY != null && now() <= lockUntil) burstRestore();
      return res;
    };
  }

  wrapHistory('replaceState');
  wrapHistory('pushState');

  document.addEventListener('click', function (e) {
    var t = e.target;
    if (!t) return;

    if (
      (t.closest && t.closest('label[for]')) ||
      (t.matches && t.matches('input[type="radio"], input[type="checkbox"]')) ||
      (t.closest && t.closest('variant-picker')) ||
      (t.closest && t.closest('[data-option-value]'))
    ) {
      lock();
      burstRestore();
    }
  }, true);

  document.addEventListener('change', function (e) {
    var t = e.target;
    if (!t) return;

    if (
      (t.matches && t.matches('input[type="radio"], select[name="id"]')) ||
      (t.closest && t.closest('variant-picker')) ||
      (t.matches && t.matches('[data-option-value]'))
    ) {
      lock();
      burstRestore();
    }
  }, true);

  window.addEventListener('resize', function () {
    if (lockedY != null && now() <= lockUntil) burstRestore();
  }, { passive: true });

  var mo = new MutationObserver(function () {
    if (lockedY != null && now() <= lockUntil) burstRestore();
  });
  mo.observe(document.documentElement, { childList: true, subtree: true });
})();
</script>


