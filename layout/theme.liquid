<script>
(function () {
  function apply(root) {
    var scope = root || document;
    var groups = scope.querySelectorAll(".swatches--variant");
    if (!groups.length) return;

    for (var g = 0; g < groups.length; g++) {
      var group = groups[g];
      var inputs = group.querySelectorAll('input[type="radio"]');

      for (var i = 0; i < inputs.length; i++) {
        var input = inputs[i];
        var label = group.querySelector('label[for="' + input.id + '"]');
        if (!label) continue;

        if (!label.classList.contains("color-swatch")) {
          label.style.removeProperty("outline");
          label.style.removeProperty("outline-offset");
          continue;
        }

        if (input.checked) {
          label.style.setProperty("outline", "1px solid #000", "important");
        } else {
          label.style.removeProperty("outline");
          label.style.removeProperty("outline-offset");
        }
      }
    }
  }

  function boot() {
    apply(document);

    document.addEventListener("change", function (e) {
      var t = e.target;
      if (!t || t.type !== "radio") return;

      var group = t.closest(".swatches--variant");
      if (!group) return;

      apply(group);
    });

    var root = document.querySelector("product-info") || document.body;
    var obs = new MutationObserver(function (mutations) {
      for (var i = 0; i < mutations.length; i++) {
        var target = mutations[i].target;
        if (target && target.nodeType === 1) {
          apply(target);
        }
      }
    });

    obs.observe(root, { childList: true, subtree: true, attributes: true });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", boot);
  } else {
    boot();
  }
})();
</script>



<script>
(function () {
  var MODAL_ID = "cw-quickview-modal";
  var STYLE_ID = "cw-quickview-style";

  function isMobile() {
    return window.matchMedia("(max-width: 768px)").matches;
  }

  function ensureStyle() {
    if (document.getElementById(STYLE_ID)) return;
    var s = document.createElement("style");
    s.id = STYLE_ID;
    s.textContent = ""
      + "#" + MODAL_ID + "{position:fixed;inset:0;z-index:999999;display:none;align-items:center;justify-content:center;padding:16px;background:rgba(0,0,0,.55)}"
      + "#" + MODAL_ID + "[data-open='1']{display:flex}"
      + "#" + MODAL_ID + " .cwqv-panel{position:relative;width:min(980px,100%);max-height:min(88vh,100%);overflow:auto;background:#fff;box-shadow:0 20px 60px rgba(0,0,0,.35)}"
      + "#" + MODAL_ID + " .cwqv-close{position:absolute;top:10px;left:10px;z-index:3;width:38px;height:38px;border-radius:999px;border:0;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 24px rgba(0,0,0,.18)}"
      + "#" + MODAL_ID + " .cwqv-close svg{width:18px;height:18px}"
      + "#" + MODAL_ID + " .cwqv-body{padding:18px}"
      + "#" + MODAL_ID + " .cwqv-body .quick-add{display:none!important}"
      + "#" + MODAL_ID + " .cwqv-footer{position:sticky;bottom:0;left:0;right:0;padding:12px 18px;background:#fff;border-top:1px solid rgba(0,0,0,.08);z-index:2}"
      + "#" + MODAL_ID + " .cwqv-atc{width:100%}";
    document.head.appendChild(s);
  }

  function ensureModal() {
    var existing = document.getElementById(MODAL_ID);
    if (existing) return existing;

    var wrap = document.createElement("div");
    wrap.id = MODAL_ID;

    var panel = document.createElement("div");
    panel.className = "cwqv-panel";

    var closeBtn = document.createElement("button");
    closeBtn.type = "button";
    closeBtn.className = "cwqv-close";
    closeBtn.setAttribute("aria-label", "Close quick view");
    closeBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M18 6L6 18" stroke="black" stroke-width="2" stroke-linecap="round"/><path d="M6 6L18 18" stroke="black" stroke-width="2" stroke-linecap="round"/></svg>';

    var body = document.createElement("div");
    body.className = "cwqv-body";

    var footer = document.createElement("div");
    footer.className = "cwqv-footer";

    var atc = document.createElement("button");
    atc.type = "button";
    atc.className = "button button--primary cwqv-atc";
    atc.setAttribute("is", "hover-button");
    atc.innerHTML = '<span class="btn-fill" data-fill=""></span><span class="btn-text">Add to cart</span><span class="btn-loader"><span></span><span></span><span></span></span>';

    footer.appendChild(atc);
    panel.appendChild(closeBtn);
    panel.appendChild(body);
    panel.appendChild(footer);
    wrap.appendChild(panel);
    document.body.appendChild(wrap);

    closeBtn.addEventListener("click", function () {
      closeModal();
    });

    wrap.addEventListener("click", function (e) {
      if (e.target === wrap) closeModal();
    });

    return wrap;
  }

  function lockScroll(lock) {
    if (lock) {
      document.documentElement.style.overflow = "hidden";
      document.body.style.overflow = "hidden";
    } else {
      document.documentElement.style.overflow = "";
      document.body.style.overflow = "";
    }
  }

  function findProductUrl(card) {
    if (!card) return "";
    var a = card.querySelector("a[href*='/products/']");
    if (!a) return "";
    var href = a.getAttribute("href") || "";
    if (!href) return "";
    if (href.indexOf("http") === 0) return href;
    return href.charAt(0) === "/" ? href : ("/" + href);
  }

  async function addFirstAvailableVariant(productUrl) {
    if (!productUrl) throw new Error("missing_product_url");
    var res = await fetch(productUrl.replace(/\?.*$/, "") + ".js", { credentials: "same-origin" });
    if (!res.ok) throw new Error("product_json_failed");
    var product = await res.json();
    var variants = Array.isArray(product.variants) ? product.variants : [];
    var v = variants.find(function (x) { return !!x.available; }) || variants[0];
    if (!v || !v.id) throw new Error("no_variant");
    var addRes = await fetch("/cart/add.js", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      credentials: "same-origin",
      body: JSON.stringify({ id: v.id, quantity: 1 })
    });
    if (!addRes.ok) throw new Error("cart_add_failed");
    return addRes.json();
  }

  function openModalWithClone(fromBtn) {
    ensureStyle();
    var modal = ensureModal();
    var body = modal.querySelector(".cwqv-body");
    var atcBtn = modal.querySelector(".cwqv-atc");
    body.innerHTML = "";

    var card = fromBtn.closest("[data-product-id], .product-card, .product-item, .card, li, article, .grid__item");
    if (!card) return;

    var clone = card.cloneNode(true);
    clone.removeAttribute("id");
    body.appendChild(clone);

    var productUrl = findProductUrl(card);
    atcBtn.disabled = !productUrl;
    atcBtn.dataset.productUrl = productUrl || "";

    modal.setAttribute("data-open", "1");
    lockScroll(true);
  }

  function closeModal() {
    var modal = document.getElementById(MODAL_ID);
    if (!modal) return;
    modal.removeAttribute("data-open");
    lockScroll(false);
    var body = modal.querySelector(".cwqv-body");
    if (body) body.innerHTML = "";
    var atcBtn = modal.querySelector(".cwqv-atc");
    if (atcBtn) {
      atcBtn.disabled = false;
      atcBtn.removeAttribute("aria-busy");
      atcBtn.dataset.productUrl = "";
    }
  }

  document.addEventListener("keydown", function (e) {
    if (e.key === "Escape") closeModal();
  });

  document.addEventListener("click", function (e) {
    if (!isMobile()) return;

    var btn = e.target.closest(".quick-add button[aria-label='Choose options'], .quick-add button[aria-controls^='Quickview-']");
    if (!btn) return;

    e.preventDefault();
    e.stopPropagation();
    openModalWithClone(btn);
  }, true);

  document.addEventListener("click", async function (e) {
    var atcBtn = e.target.closest("#" + MODAL_ID + " .cwqv-atc");
    if (!atcBtn) return;

    var url = atcBtn.dataset.productUrl || "";
    if (!url) return;

    atcBtn.disabled = true;
    atcBtn.setAttribute("aria-busy", "true");

    try {
      await addFirstAvailableVariant(url);
      window.location.href = "/cart";
    } catch (err) {
      atcBtn.disabled = false;
      atcBtn.removeAttribute("aria-busy");
    }
  }, true);
})();
</script>
<script>
(function () {
  var MODAL_ID = "cw-quickview-modal";
  var PATCH_STYLE_ID = "cwqv-advanced-slideup-style";
  var PATCH_FLAG = "cwqvAnimBound";

  if (!document.getElementById(PATCH_STYLE_ID)) {
    var s = document.createElement("style");
    s.id = PATCH_STYLE_ID;
    s.textContent = ""
      + "#" + MODAL_ID + "{align-items:flex-end!important;justify-content:center!important;padding:0!important;overflow:hidden!important}"
      + "#" + MODAL_ID + " .cwqv-panel{width:100%!important;will-change:transform,opacity}"

      + "#" + MODAL_ID + ".cwqv-anim-open .cwqv-panel{animation:cwqvSlideUp .78s cubic-bezier(.16,1,.3,1) both}"
      + "#" + MODAL_ID + ".cwqv-anim-close .cwqv-panel{animation:cwqvSlideDown .42s cubic-bezier(.4,0,1,1) both}"

      + "@keyframes cwqvSlideUp{"
      + "0%{transform:translate3d(0,100%,0);opacity:0.98}"
      + "65%{transform:translate3d(0,-10px,0);opacity:1}"
      + "82%{transform:translate3d(0,4px,0)}"
      + "100%{transform:translate3d(0,0,0);opacity:1}"
      + "}"

      + "@keyframes cwqvSlideDown{"
      + "0%{transform:translate3d(0,0,0);opacity:1}"
      + "100%{transform:translate3d(0,100%,0);opacity:0.98}"
      + "}";
    document.head.appendChild(s);
  }

  function bindOnce(modal) {
    if (!modal || modal[PATCH_FLAG]) return;
    modal[PATCH_FLAG] = true;

    var panel = modal.querySelector(".cwqv-panel");
    if (!panel) return;

    function playOpen() {
      modal.classList.remove("cwqv-anim-close");
      modal.classList.remove("cwqv-anim-open");
      panel.style.animation = "none";
      panel.offsetHeight;
      panel.style.animation = "";
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          modal.classList.add("cwqv-anim-open");
        });
      });
    }

    function playCloseAndThenHide() {
      modal.classList.remove("cwqv-anim-open");
      modal.classList.add("cwqv-anim-close");
      var ms = 420;

      window.setTimeout(function () {
        if (modal.getAttribute("data-open") !== "1") return;
        modal.removeAttribute("data-open");
        modal.classList.remove("cwqv-anim-close");
        document.documentElement.style.overflow = "";
        document.body.style.overflow = "";
        var body = modal.querySelector(".cwqv-body");
        if (body) body.innerHTML = "";
        var atcBtn = modal.querySelector(".cwqv-atc");
        if (atcBtn) {
          atcBtn.disabled = false;
          atcBtn.removeAttribute("aria-busy");
          atcBtn.dataset.productUrl = "";
        }
      }, ms);
    }

    var mo = new MutationObserver(function (mutations) {
      for (var i = 0; i < mutations.length; i++) {
        if (mutations[i].attributeName === "data-open") {
          if (modal.getAttribute("data-open") === "1") playOpen();
        }
      }
    });
    mo.observe(modal, { attributes: true });

    modal.addEventListener("click", function (e) {
      if (e.target === modal) {
        e.preventDefault();
        e.stopPropagation();
        playCloseAndThenHide();
      }
      var closeBtn = e.target.closest(".cwqv-close");
      if (closeBtn) {
        e.preventDefault();
        e.stopPropagation();
        playCloseAndThenHide();
      }
    }, true);

    document.addEventListener("keydown", function (e) {
      if (e.key !== "Escape") return;
      if (modal.getAttribute("data-open") !== "1") return;
      e.preventDefault();
      playCloseAndThenHide();
    }, true);

    if (modal.getAttribute("data-open") === "1") playOpen();
  }

  function tryBind() {
    var modal = document.getElementById(MODAL_ID);
    if (!modal) return;
    bindOnce(modal);
  }

  tryBind();
  var poll = 0;
  var t = window.setInterval(function () {
    poll++;
    tryBind();
    if (document.getElementById(MODAL_ID) || poll > 60) window.clearInterval(t);
  }, 250);
})();
</script>



