<script>
(function () {
  const root = document;

  const getInputFromTarget = (t) => {
    if (!t) return null;
    if (t.matches && t.matches('input[type="radio"][data-option-value]')) return t;

    const label = t.closest && t.closest('label[for]');
    if (label) {
      const id = label.getAttribute('for');
      if (id) return document.getElementById(id);
    }

    const li = t.closest && t.closest('li');
    if (li) {
      const input = li.querySelector && li.querySelector('input[type="radio"][data-option-value]');
      if (input) return input;
    }

    return null;
  };

  const updateUi = (input) => {
    const fieldset = input.closest('fieldset');
    if (fieldset) {
      const valueSpan = fieldset.querySelector('.form__label .font-medium');
      if (valueSpan) valueSpan.textContent = input.value;
      fieldset.setAttribute('data-last-picked', input.value);
    }

    const li = input.closest('li');
    if (li) {
      const ul = li.closest('ul');
      if (ul) ul.querySelectorAll('li').forEach((x) => x.classList.remove('is-picked'));
      li.classList.add('is-picked');
    }
  };

  const forcePick = (input) => {
    if (!input) return;
    if (input.disabled) return;

    input.checked = true;

    input.dispatchEvent(new Event('input', { bubbles: true }));
    input.dispatchEvent(new Event('change', { bubbles: true }));

    updateUi(input);
  };

  root.addEventListener('click', (e) => {
    const input = getInputFromTarget(e.target);
    if (!input) return;

    e.preventDefault();
    e.stopPropagation();

    forcePick(input);

    try {
      console.log('[swatch-click]', {
        id: input.id,
        name: input.name,
        value: input.value,
        checked: input.checked
      });
    } catch (_) {}
  }, true);

  const style = document.createElement('style');

  document.head.appendChild(style);
})();
</script>

