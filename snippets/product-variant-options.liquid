{% comment %}
Renders product variant options

Accepts:
- product: {Object} product object.
- option: {Object} current product_option object.
- block: {Object} block object.


Usage:
{% render 'product-variant-options',
    product: product,
    option: option,
    block: block
  %}
{% endcomment %}


{%- liquid
  assign variants_available_arr = product.variants | map: 'available'
  assign variants_option1_arr = product.variants | map: 'option1'
  assign variants_option2_arr = product.variants | map: 'option2'
  assign variants_option3_arr = product.variants | map: 'option3'

  assign product_form_id = 'product-form-' | append: section.id
-%}

<style>
.product-form__input input[type=radio]+label.variant-swatch {
    background-size: cover;
    background-position: center;
    width: 8rem !important;
    display: inline-block;
    padding: 0px;
    background: none;
    box-sizing: border-box;
}

input[type="radio"] + .variant-swatch {
border: 1px solid transparent;
}

.product-form__input input[type=radio] + label.variant-swatch {
    border: 1px solid transparent;
}

.product-form__input input[type=radio]:checked + label.variant-swatch {
    border: 1px solid black;
}


.variant-swatch {
    box-sizing: border-box;
    line-height: 0;
    vertical-align: top;
}
.variant-swatch img {
    display: block;
    box-sizing: border-box;
    width: 100%;
}


@media (max-width: 749px) {
    .product-form__input input[type=radio]+label.variant-swatch {
      width: 6rem !important;
    }
}


</style>


{%- for value in option.values -%}
{%- liquid
  assign option_disabled = true
  assign variant_index = -1 
  for option1_name in variants_option1_arr
    case option.position
      when 1
        if variants_option1_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
          assign option_disabled = false
          assign variant_index = forloop.index0 
        endif
      when 2
        if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
          assign option_disabled = false
          assign variant_index = forloop.index0 
        endif
      when 3
        if option1_name == product.selected_or_first_available_variant.option1 and variants_option2_arr[forloop.index0] == product.selected_or_first_available_variant.option2 and variants_option3_arr[forloop.index0] == value and variants_available_arr[forloop.index0]
          assign option_disabled = false
          assign variant_index = forloop.index0 
        endif
    endcase
  endfor
-%}

{%- if block.settings.picker_type == 'button' -%}
{%- assign option_name_lowercase = option.name | downcase -%}
{% if variant_index != -1 and option_name_lowercase == 'color' %}

<input type="radio" id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" name="{{ option.name }}"
  value="{{ value | escape }}" form="{{ product_form_id }}" {% if option.selected_value == value %} checked {% endif %}
  {% if option_disabled %} class="disabled" {% endif %}>




  <label class="variant-swatch" 
  {% if variant_index != -1 and option_name_lowercase == 'color' %}
    {%- assign variant = product.variants[variant_index] -%}
    {%- assign variant_image = variant.image | img_url: 'medium' -%} 
  {% endif %} 
  for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
    <img src="{{ variant_image }}" alt="Swatch for {{ variant.title }}" class="hidden-swatch-img">
    <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
  </label>
  

{% comment %} 
<label class="variant-swatch" 
{% if variant_index != -1 and option_name_lowercase == 'color' %}
  {%- assign variant = product.variants[variant_index] -%}
  {%- assign variant_image = variant.image | img_url: 'small' -%} style="
    background-image: url('{{ variant_image }}');
    
    " {% endif %} for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
  <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
</label> 
{% endcomment %}



<!-- JavaScript to update the displayed color name -->
<script>
    // Define a function to update the color name
    function updateColorName() {
        // Find the checked color radio button
        var checkedColorInput = document.querySelector('input[name="{{ option.name }}"]:checked');
        // If a color radio button is checked
        if (checkedColorInput) {
            // Get the color value from the checked radio button
            var selectedColorValue = checkedColorInput.value;
            // Get the displayed color name element
            var colorNameElement = document.getElementById('selected-color');
            // Update the displayed color name
            colorNameElement.textContent = selectedColorValue;
        }
    }

    // Get all color radio buttons
    var colorRadioButtons = document.querySelectorAll('input[name="{{ option.name }}"]');
    // Add a change event listener to each color radio button
    colorRadioButtons.forEach(function(radioButton) {
        radioButton.addEventListener('change', updateColorName);
    });

    // Initial call to set the color name on page load
    updateColorName();
</script>



{% else %}

<input type="radio" id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}" name="{{ option.name }}"
  value="{{ value | escape }}" form="{{ product_form_id }}" {% if option.selected_value == value %} checked {% endif %}
  {% if option_disabled %} class="disabled" {% endif %}>
<label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
  {{ value -}}
  <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
</label>

{% endif %}


{%- elsif block.settings.picker_type == 'dropdown' -%}
<option value="{{ value | escape }}" {% if option.selected_value == value %} selected="selected" {% endif %}>
  {% if option_disabled -%}
  {{- 'products.product.value_unavailable' | t: option_value: value -}}
  {%- else -%}
  {{- value -}}
  {%- endif %}
</option>
{%- endif -%}
{%- endfor -%}






