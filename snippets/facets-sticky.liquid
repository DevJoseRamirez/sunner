{%- doc -%}
  Renders a scroll-triggered sticky filter button with drawer for mobile/tablet devices.

  Appears on scroll and provides access to filtering/sorting in a slide-out drawer.

  @param {object} results - Shopify collection or search results object
  @param {boolean} [enable_filtering] - Enable filter options in drawer
  @param {boolean} [enable_sorting] - Enable sort options in drawer
  @param {boolean} [enable_color_swatches] - Display colors as swatches
  @param {boolean} [collapsed] - Start filter groups collapsed
  @param {number} filter_count - Active filter count for badge display
  @param {string} section_id - Parent section ID for state tracking

  @example
  {% render 'facets-sticky',
     results: collection,
     enable_filtering: true,
     enable_sorting: true,
     enable_color_swatches: true,
     filter_count: filter_count,
     section_id: section.id
  %}
{%- enddoc -%}


{%- if enable_filtering or enable_sorting -%}
  <facet-sticky class="facet-sticky z-25 fixed left-0 text-center w-full pointer-events-none block xl:hidden" data-scroll data-scroll-sticky data-scroll-target=".collection">
    <button type="button" class="button button--primary icon-with-text pointer-events-auto" is="hover-button" aria-controls="FacetDrawerSticky" aria-expanded="false">
      <span class="btn-fill" data-fill></span>
      <span class="btn-text">
        {%- liquid
          render 'icon', icon: 'filter', size: 'sm'
          if enable_filtering and enable_sorting
            echo 'collections.filtering.filter_and_sort' | t
          else
            echo 'collections.filtering.filter_show_button' | t
          endif
        -%}
        {%- if enable_filtering -%}
          <facet-count class="facet-count flex items-center justify-center text-xs font-medium rounded-full"{% if filter_count == 0 %} hidden{% endif %}>{{ filter_count }}</facet-count>
        {%- endif -%}
      </span>
    </button>
    <drawer-element id="FacetDrawerSticky" class="facet-drawer drawer drawer--start z-30 fixed bottom-0 left-0 h-full w-full pointer-events-none"
      role="dialog"
      aria-modal="true"
      aria-label="{% if enable_filtering and enable_sorting %}{{ 'collections.filtering.filter_and_sort' | t | escape }}{% else %}{{ 'collections.filtering.filter_by_label' | t | escape }}{% endif %}"
      data-section-id="{{ section_id }}"
      hidden
    >
      <overlay-element class="overlay fixed-modal invisible opacity-0 fixed bottom-0 left-0 w-full h-screen pointer-events-none" aria-controls="FacetDrawerSticky" aria-expanded="false"></overlay-element>
      <div class="drawer__inner z-10 absolute top-0 flex flex-col w-full h-full overflow-hidden">
        <gesture-element class="drawer__header flex justify-between opacity-0 invisible relative" tabindex="0">
          <span class="drawer__title heading lg:text-3xl text-2xl leading-none tracking-tight">
            {%- liquid
              if enable_filtering and enable_sorting
                echo 'collections.filtering.filter_and_sort' | t | escape
              else
                echo 'collections.filtering.filter_by_label' | t | escape
              endif
            -%}
          </span>
          <button class="button button--secondary button--close drawer__close hidden sm:flex items-center justify-center" type="button" is="hover-button" aria-controls="FacetDrawerSticky" aria-expanded="false" aria-label="{{ 'general.accessibility.close' | t | escape }}">
            <span class="btn-fill" data-fill></span>
            <span class="btn-text">
              {%- liquid
                render 'icon', icon: 'close', size: 'sm'
                render 'icon', icon: 'loader', size: 'sm absolute opacity-0 invisible animate-spin'
              -%}
            </span>
          </button>
        </gesture-element>
        <div class="drawer__content opacity-0 invisible flex flex-col h-full grow shrink" id="MobileFacetFiltersContainer">
          <div class="drawer__scrollable relative flex flex-col grow shrink">
            {%- render 'facets',
              context: 'sticky',
              results: results,
              collapsed: collapsed,
              enable_filtering: enable_filtering,
              enable_sorting: enable_sorting,
              enable_color_swatches: enable_color_swatches,
              section_id: section_id
            -%}
  
            <div class="drawer__sticky z-1 sticky left-0 bottom-0 w-full">
              <button class="button button--primary w-full" type="button" is="hover-button" aria-controls="FacetDrawerSticky" aria-expanded="false">
                <span class="btn-fill" data-fill></span>
                <span class="btn-text flex gap-1">
                  {{- 'collections.filtering.view_results' | t -}}
                  <results-count class="block">{{ results.results_count | default: results.products_count }}</results-count>
                </span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </drawer-element>
  </facet-sticky>

  <script>
(function () {
  function init(root) {
    var openBtn = root.querySelector('button[aria-controls="FacetDrawerSticky"]');
    var drawer = root.querySelector('#FacetDrawerSticky');
    if (!openBtn || !drawer) return;

    var btnText = openBtn.querySelector('.btn-text');
    if (!btnText) return;

    var existing = btnText.querySelector('.facet-sticky__label');
    if (!existing) {
      var wrap = document.createElement('span');
      wrap.className = 'facet-sticky__label';
      while (btnText.firstChild) wrap.appendChild(btnText.firstChild);
      btnText.appendChild(wrap);
    }

    var loadingLabel = btnText.querySelector('.facet-sticky__loading-label');
    if (!loadingLabel) {
      loadingLabel = document.createElement('span');
      loadingLabel.className = 'facet-sticky__loading-label';
      loadingLabel.textContent = 'Filtering...';
      loadingLabel.setAttribute('aria-hidden', 'true');
      btnText.appendChild(loadingLabel);
    }

    if (!document.getElementById('facet-sticky-loading-style')) {
      var style = document.createElement('style');
      style.id = 'facet-sticky-loading-style';
      style.textContent =
        'facet-sticky .facet-sticky__loading-label{display:none;}' +
        'facet-sticky .button.is-loading{opacity:.55;filter:grayscale(1);pointer-events:none;}' +
        'facet-sticky .button.is-loading .facet-sticky__label{display:none;}' +
        'facet-sticky .button.is-loading .facet-sticky__loading-label{display:inline-flex;align-items:center;gap:8px;}';
      document.head.appendChild(style);
    }

    var clearTimer = null;

    function setLoading(on) {
      if (on) {
        openBtn.classList.add('is-loading');
        openBtn.setAttribute('aria-busy', 'true');
        clearTimeout(clearTimer);
        clearTimer = setTimeout(function () {
          openBtn.classList.remove('is-loading');
          openBtn.removeAttribute('aria-busy');
        }, 1200);
      } else {
        clearTimeout(clearTimer);
        openBtn.classList.remove('is-loading');
        openBtn.removeAttribute('aria-busy');
      }
    }

    openBtn.addEventListener('click', function () {
      setLoading(true);
    });

    var obs = new MutationObserver(function () {
      var isOpen = !drawer.hasAttribute('hidden');
      if (isOpen) setTimeout(function () { setLoading(false); }, 150);
      else setLoading(false);
    });

    obs.observe(drawer, { attributes: true, attributeFilter: ['hidden'] });
  }

  document.querySelectorAll('facet-sticky').forEach(init);

  var rootObs = new MutationObserver(function () {
    document.querySelectorAll('facet-sticky').forEach(function (el) {
      if (el.__facetStickyLoadingInit) return;
      el.__facetStickyLoadingInit = true;
      init(el);
    });
  });

  rootObs.observe(document.documentElement, { childList: true, subtree: true });
})();
</script>

<script>
(function () {
  var DELAY = 500;
  var PATCH_STYLE_ID = "cw-filter-delay-anim-style";
  var allowNext = false;
  var lock = false;

  if (!document.getElementById(PATCH_STYLE_ID)) {
    var s = document.createElement("style");
    s.id = PATCH_STYLE_ID;
    s.textContent =
      "[aria-controls='FacetDrawerSticky'].cw-filter-opening{pointer-events:none}" +
      "[aria-controls='FacetDrawerSticky'].cw-filter-opening .icon-loader{opacity:1!important;visibility:visible!important}" +
      "[aria-controls='FacetDrawerSticky'].cw-filter-opening svg:not(.icon-loader){opacity:0!important;visibility:hidden!important}";
    document.head.appendChild(s);
  }

  document.addEventListener("click", function (e) {
    var btn = e.target.closest("[aria-controls='FacetDrawerSticky']");
    if (!btn) return;

    if (allowNext) {
      allowNext = false;
      return;
    }

    if (lock) {
      e.preventDefault();
      e.stopImmediatePropagation();
      return;
    }

    lock = true;
    e.preventDefault();
    e.stopImmediatePropagation();

    btn.classList.add("cw-filter-opening");

    setTimeout(function () {
      btn.classList.remove("cw-filter-opening");
      allowNext = true;
      lock = false;
      btn.dispatchEvent(new MouseEvent("click", { bubbles: true, cancelable: true, view: window }));
    }, DELAY);
  }, true);
})();
</script>
{%- endif -%}