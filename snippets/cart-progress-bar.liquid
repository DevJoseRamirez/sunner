{% style %}
    .cart-progress {
  /* margin: 1.5rem 0; */
  margin-bottom: 1.5rem ;
  padding: 1rem;
  background: #f8f8f8;
  border-radius: 8px;
  text-align: center;
}

.cart-progress__label {
 font-size: 1.5rem;
  margin: 0.8rem 0;
}

.cart-progress__bar {
  height: 8px;
  background: #eee;
  border-radius: 4px;
  overflow: hidden;
}

.cart-progress__fill {
  height: 100%;
  width: 0%;
  background: #ff385c;
  transition: width 0.3s ease;
}

.cart-progress__milestones {
  margin: 0.8rem 0;
  font-size: 1.5rem;
  color: #888;
}

.milestone {
  display: inline-block;
  margin: 0 auto;
}

.product-form__free-gift-notice {
  margin: 1rem 0;
  font-size: 1rem;
  color: #333;
}
.free-gift-notice__text {
  font-weight: 500;
}


.cart-progress__bar {
  position: relative;
  width: 100%;
  height: 8px;
  background: #eee;
  border-radius: 4px;
  overflow: hidden;
  margin: .5rem 0rem;
}

.cart-progress__fill {
  display: block !important;
  width: 0%;               /* will be overridden by JS */
  height: 100%;
  background: #ff385c;     /* your fill color */
  transition: width .3s ease;
}

{% endstyle %}


<div
  class="cart-progress"
  data-threshold="5000"
>
  <p class="cart-progress__label" aria-live="polite">
    You are <span class="cart-progress__remaining">$50.00</span> away from your free gift!
  </p>
  <div
    class="cart-progress__bar"
    role="progressbar"
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuenow="0"
  >
    <div class="cart-progress__fill" style="width:0%"></div>
  </div>
  <div class="cart-progress__milestones">
    <div class="milestone">🎁 Free gift at $50</div>
  </div>
</div>
