<script>
(function () {
  const SHOW_PREORDER_BUTTON = {{ block.settings.show_pre_order_button | default: false | json }};
  const SHIPPING_TEXT = 'Ships 6/17';

  const script = document.currentScript;
  const root = script ? script.closest('.product-form-wrapper') : document;

  function getAddToCartButton() {
    return root.querySelector('.product-form__submit[name="add"]');
  }

  function removePreorderCTA() {
    root.querySelectorAll('.cw-preorder-cta').forEach(function (el) {
      el.remove();
    });

    root.querySelectorAll('.cw-preorder-ships').forEach(function (el) {
      el.remove();
    });

    const atc = getAddToCartButton();
    if (atc) {
      atc.style.display = '';
    }
  }

  function applyPreorderCTA() {
    const atc = getAddToCartButton();

    if (!atc) return;

    removePreorderCTA();

    if (!SHOW_PREORDER_BUTTON) return;

    const cloned = atc.cloneNode(true);
    cloned.type = 'button';
    cloned.removeAttribute('name');
    cloned.removeAttribute('form');
    cloned.removeAttribute('disabled');
    cloned.classList.add('cw-preorder-cta');

    const btnText = cloned.querySelector('.btn-text');
    if (btnText) {
      btnText.innerHTML = '<span>PRE ORDER</span>';
    }

    cloned.addEventListener('click', function () {
      cloned.classList.add('is-clicked');

      setTimeout(function () {
        cloned.classList.remove('is-clicked');
      }, 180);

      atc.click();
    });

    const ships = document.createElement('div');
    ships.className = 'cw-preorder-ships';
    ships.textContent = SHIPPING_TEXT;

    atc.insertAdjacentElement('afterend', cloned);
    cloned.insertAdjacentElement('afterend', ships);

    atc.style.display = 'none';
  }

  function initPreorderCTA() {
    setTimeout(applyPreorderCTA, 50);
    setTimeout(applyPreorderCTA, 250);
  }

  document.addEventListener('change', function (event) {
    if (event.target.matches('input[type="radio"], select')) {
      initPreorderCTA();
    }
  });

  document.addEventListener('shopify:section:load', initPreorderCTA);
  document.addEventListener('shopify:block:select', initPreorderCTA);
  document.addEventListener('shopify:section:select', initPreorderCTA);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPreorderCTA);
  } else {
    initPreorderCTA();
  }
})();

function removeCartPreorderText() {
  document.querySelectorAll('.text-xs.text-opacity.leading-tight').forEach(function (el) {
    if ((el.textContent || '').trim().includes('Pre Order:') && (el.textContent || '').trim().includes('Ships 6/4')) {
      el.remove();
    }
  });
}

removeCartPreorderText();
</script>

